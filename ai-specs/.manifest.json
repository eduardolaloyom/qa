{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "ai-specs update manifest. Classifies framework files by update strategy.",
  "version": "1.0.0",
  "categories": {
    "safe_to_overwrite": {
      "description": "Generic framework files that are NOT customized per project. These get replaced directly from upstream on update.",
      "files": [
        "ai-specs/.manifest.json",
        "ai-specs/specs/base-standards.mdc"
      ]
    },
    "adapted": {
      "description": "YOM QA-specific files. Require review before updating — never safe to overwrite blindly.",
      "files": [
        "ai-specs/specs/qa-standards.mdc",
        "ai-specs/specs/maestro-standards.mdc",
        "ai-specs/specs/admin-testing-standards.mdc",
        "ai-specs/specs/qa-coverage-mapping.mdc",
        "ai-specs/specs/qa-listo-criteria.mdc",
        "ai-specs/.agents/qa-coordinator.md",
        "ai-specs/.agents/playwright-specialist.md",
        "ai-specs/.agents/playwright-failure-analyst.md",
        "ai-specs/.agents/maestro-specialist.md",
        "ai-specs/.agents/data-pipeline-specialist.md",
        "ai-specs/.agents/weekly-qa-pulse.md",
        "ai-specs/.agents/repo-cleanup-specialist.md",
        "ai-specs/.commands/qa-plan-client.md",
        "ai-specs/.commands/run-playwright.md",
        "ai-specs/.commands/report-qa.md",
        "ai-specs/.commands/triage-playwright.md",
        "ai-specs/.commands/qa-coverage-analysis.md",
        "ai-specs/.commands/qa-client-validation.md",
        "ai-specs/.commands/qa-improve.md",
        "ai-specs/.commands/sync-qa-data.md",
        "ai-specs/.commands/weekly-qa-pulse.md",
        "ai-specs/.commands/cleanup-repo.md",
        "CLAUDE.md"
      ]
    },
    "symlinks": {
      "description": "Copies in .claude/commands/ that mirror ai-specs/.commands/. Recreate if missing.",
      "files": [
        ".claude/commands/qa-plan-client.md",
        ".claude/commands/run-playwright.md",
        ".claude/commands/report-qa.md",
        ".claude/commands/triage-playwright.md",
        ".claude/commands/qa-coverage-analysis.md",
        ".claude/commands/qa-client-validation.md",
        ".claude/commands/qa-improve.md",
        ".claude/commands/sync-qa-data.md",
        ".claude/commands/weekly-qa-pulse.md",
        ".claude/commands/cleanup-repo.md"
      ]
    },
    "ignored": {
      "description": "Project-specific generated files and archived content. Never touched during updates.",
      "patterns": [
        "ai-specs/changes/*",
        "_archived/*",
        "QA/*",
        "data/qa-matrix.json",
        "tests/e2e/fixtures/clients.ts",
        "public/manifest.json",
        "public/live.json"
      ]
    }
  }
}
