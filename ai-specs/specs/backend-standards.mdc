## Domain-Driven Design Principles

### Entities

Entities have identity and encapsulate business behavior:

```typescript
// Good: Entity with behavior, validates invariants in constructor
export class Candidate {
  private constructor(
    public readonly id: CandidateId,
    private email: Email,
    private name: FullName,
    private applications: Application[] = [],
  ) {}

  static create(props: CreateCandidateProps): Candidate {
    return new Candidate(
      CandidateId.generate(),
      Email.create(props.email),
      FullName.create(props.firstName, props.lastName),
    );
  }

  applyForPosition(position: Position): Application {
    if (this.hasAppliedTo(position.id)) {
      throw new DuplicateApplicationError(this.id, position.id);
    }
    const application = Application.create(this.id, position.id);
    this.applications.push(application);
    return application;
  }

  private hasAppliedTo(positionId: PositionId): boolean {
    return this.applications.some(a => a.positionId.equals(positionId));
  }
}

// Bad: Anemic entity — just a data bag with no behavior
export class Candidate {
  id: string;
  email: string;
  name: string;
}
```

### Value Objects

Immutable, validated at construction time:

```typescript
export class Email {
  private constructor(private readonly value: string) {}

  static create(raw: string): Email {
    if (!raw || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(raw)) {
      throw new InvalidEmailError(raw);
    }
    return new Email(raw.toLowerCase().trim());
  }

  getValue(): string {
    return this.value;
  }

  equals(other: Email): boolean {
    return this.value === other.value;
  }
}
```

### Repository Interfaces (Ports)

Define interfaces in the domain layer — implementations go in infrastructure:

```typescript
// domain/repositories/candidate.repository.interface.ts
export interface ICandidateRepository {
  findById(id: CandidateId): Promise<Candidate | null>;
  findByEmail(email: Email): Promise<Candidate | null>;
  save(candidate: Candidate): Promise<void>;
  delete(id: CandidateId): Promise<void>;
}

// In NestJS, register with a token for injection:
export const CANDIDATE_REPOSITORY = Symbol('ICandidateRepository');
```

### Domain Events

Use domain events for side effects that cross aggregate boundaries:

```typescript
export class CandidateAppliedEvent {
  constructor(
    public readonly candidateId: CandidateId,
    public readonly positionId: PositionId,
    public readonly appliedAt: Date,
  ) {}
}
```

