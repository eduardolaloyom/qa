## Database Patterns

### MongoDB + Mongoose (NestJS)

```typescript
// Schema definition with decorators
@Schema({ timestamps: true, collection: 'candidates' })
export class CandidateDocument {
  @Prop({ required: true, trim: true, maxlength: 100 })
  firstName: string;

  @Prop({ required: true, unique: true, lowercase: true })
  email: string;
}

export const CandidateSchema = SchemaFactory.createForClass(CandidateDocument);
CandidateSchema.index({ email: 1 }, { unique: true });
CandidateSchema.index({ createdAt: -1 });
```

```typescript
// Repository implementation
@Injectable()
export class MongoCandidateRepository implements ICandidateRepository {
  constructor(
    @InjectModel(CandidateDocument.name)
    private readonly model: Model<CandidateDocument>,
  ) {}

  async findById(id: CandidateId): Promise<Candidate | null> {
    const doc = await this.model.findById(id.value).lean().exec();
    return doc ? CandidateMapper.toDomain(doc) : null;
  }

  async save(candidate: Candidate): Promise<void> {
    const doc = CandidateMapper.toPersistence(candidate);
    await this.model.findByIdAndUpdate(doc._id, doc, { upsert: true, new: true }).exec();
  }
}
```

### Mongoose Best Practices
- Always define indexes in the schema definition
- Use `.lean()` for read-only queries — returns plain JS objects, not Mongoose documents
- Use `findByIdAndUpdate` with `upsert: true` for save/create operations
- Use `populate()` only when you need related documents in the response; avoid for performance-critical paths
- Handle Mongoose errors: `CastError` → 400, `MongoServerError` code 11000 (unique violation) → 409

### PostgreSQL + Prisma (when applicable)

```typescript
@Injectable()
export class PrismaCandidateRepository implements ICandidateRepository {
  constructor(private readonly prisma: PrismaService) {}

  async findById(id: CandidateId): Promise<Candidate | null> {
    const record = await this.prisma.candidate.findUnique({
      where: { id: id.value },
      include: { applications: true },
    });
    return record ? CandidateMapper.toDomain(record) : null;
  }
}
```

