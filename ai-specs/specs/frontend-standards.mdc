## State Management

### Server State (TanStack Query)
Use TanStack Query for all server data — it handles caching, revalidation, and loading/error states:

```typescript
export function useCandidates(filters?: CandidateFilters) {
  return useQuery({
    queryKey: ['candidates', filters],
    queryFn: () => candidateService.getAll(filters),
    staleTime: 5 * 60 * 1000,
  });
}

export function useCreateCandidate() {
  const queryClient = useQueryClient();
  return useMutation({
    mutationFn: candidateService.create,
    onSuccess: () => queryClient.invalidateQueries({ queryKey: ['candidates'] }),
  });
}
```

### Local State
- Use `useState` for simple component-level state
- Use `useReducer` for complex state logic with multiple sub-values
- Extract complex stateful logic into custom hooks

### Forms (React Hook Form + Zod)
```typescript
const schema = z.object({
  firstName: z.string().min(2).max(100),
  email: z.string().email(),
  phone: z.string().optional(),
});

type FormData = z.infer<typeof schema>;

const CandidateForm: React.FC = () => {
  const { register, handleSubmit, formState: { errors, isSubmitting } } = useForm<FormData>({
    resolver: zodResolver(schema),
  });

  return (
    <form onSubmit={handleSubmit(onSubmit)}>
      <input {...register('firstName')} />
      {errors.firstName && <span>{errors.firstName.message}</span>}
      <button type="submit" disabled={isSubmitting}>Save</button>
    </form>
  );
};
```

