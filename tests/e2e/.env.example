# Playwright E2E credentials
# Copy to .env and fill with real values
# NEVER commit .env with real credentials

# Multi-cliente B2B tests (regenerados desde qa-matrix.json por sync-clients.py)
# Clientes actualmente soportados: Codelpa, Surtiventas
# Para agregar más clientes: ejecutar python3 ../../data/mongo-extractor.py && python3 ../../tools/sync-clients.py
CODELPA_EMAIL=user@yom.ai
CODELPA_PASSWORD=your-password-here
SURTIVENTAS_EMAIL=user@yom.ai
SURTIVENTAS_PASSWORD=your-password-here

# Admin panel tests (used by admin/*.spec.ts)
ADMIN_URL=https://admin.youorder.me
