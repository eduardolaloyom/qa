# MongoDB credentials for QA tools (mongo-extractor.py)
# Copy to .env and fill with real values
# NEVER commit .env with real credentials

# Microservices cluster — contains feature flags, promotions, banners
# Databases: yom-stores, yom-promotions, b2b-marketing
MONGO_MICRO_URI=mongodb+srv://user:password@microservices-cluster.example.net/

# Legacy cluster — contains products, orders, customers, salesterms
# Database: yom-production
MONGO_LEGACY_URI=mongodb+srv://user:password@legacy-cluster.example.net/

# Integrations cluster (FUTURE) — will contain segments, user segments, overrides
# MONGO_INTEGRATIONS_URI=mongodb+srv://user:password@integrations-cluster.example.net/
